<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/LinearLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CalculatorActivity">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@mipmap/cal_background" />

    <!-- Lớp phủ mờ giúp giao diện sang trọng hơn -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Màn hình hiển thị kết quả -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#E6FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <EditText
                android:id="@+id/edtFormula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="end"
                android:inputType="text"
                android:padding="24dp"
                android:textColor="#212121"
                android:textSize="42sp"
                android:textStyle="bold"
                tools:text="1,245" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Thanh phím chức năng bộ nhớ (Memory Bar) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMC"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_mc"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_mr"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMPlus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_mplus"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMMinus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_mminus"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMS"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_ms"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtM"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/str_m"
                android:textColor="#BBFFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Bàn phím máy tính -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:stretchColumns="*"
            android:layout_weight="1">

            <!-- Hàng 1 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPercent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="%"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCE"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:text="CE"
                    app:backgroundTint="@color/red"
                    android:textSize="18sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnC"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:text="C"
                    app:backgroundTint="@color/red"
                    android:textSize="18sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="⌫"
                    android:textColor="@color/red"
                    android:textSize="22sp" />
            </TableRow>

            <!-- Hàng 2 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn1_x"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="1/x"
                    android:textColor="@color/white" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnx_2"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="x²"
                    android:textColor="@color/white" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSQRT"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="√x"
                    android:textColor="@color/white" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiv"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:onClick="processInputData"
                    android:text="÷"
                    app:backgroundTint="@color/blue"
                    android:textSize="24sp" />
            </TableRow>

            <!-- Hàng 3 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn7"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="7"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn8"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="8"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn9"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="9"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMul"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:onClick="processInputData"
                    android:text="×"
                    app:backgroundTint="@color/blue"
                    android:textSize="24sp" />
            </TableRow>

            <!-- Hàng 4 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn4"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="4"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn5"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="5"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn6"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="6"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSub"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:onClick="processInputData"
                    android:text="−"
                    app:backgroundTint="@color/blue"
                    android:textSize="24sp" />
            </TableRow>

            <!-- Hàng 5 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn1"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn2"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="2"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn3"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="3"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:onClick="processInputData"
                    android:text="+"
                    app:backgroundTint="@color/blue"
                    android:textSize="24sp" />
            </TableRow>

            <!-- Hàng 6 -->
            <TableRow android:layout_weight="1">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPM"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="+/−"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn0"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDot"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:onClick="processInputData"
                    android:text="."
                    android:textColor="@color/white"
                    android:textSize="22sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEqual"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:text="="
                    app:backgroundTint="@color/yellow"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </TableRow>
        </TableLayout>
    </LinearLayout>
</FrameLayout>